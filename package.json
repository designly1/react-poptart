  "license": "MIT",
  "private": false,
  "peerDependencies": {
    "react": "^16.8.0",
    "react-dom": "^16.8.0",
    "uuid": "^9.0.0",
    "framer-motion": "^10.12.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.1",
    "@types/uuid": "^9.0.1",
    "framer-motion": "^10.12.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.4",
    "uuid": "^9.0.0"
  }
}