{
  "name": "react-poptart",
  "version": "1.0.0",
  "description": "A nice animated toast / alerts library for React",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "scripts": {
    "build": "yarn build:esm && yarn build:cjs",
    "build:esm": "tsc",
